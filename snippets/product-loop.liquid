{%- comment -%}
  Parameters:
    products:               {Array}   Required. Array of product objects to iterate over.
    limit:                  {Number}  Required. Max number of products to render.
    products_per_row:       {Number}  Required. Passed through to product-thumbnail.
    mobile_products_per_row:{String}  Required. Passed through to product-thumbnail.
    align_height:           {Boolean} Optional. Passed through to product-thumbnail. Default: false.
    height:                 {Number}  Optional. Passed through to product-thumbnail.
    related_products:       {Boolean} Optional. When true, enables hover from block settings. Default: false.
    skip_product:           {Object}  Optional. Product to exclude from the loop — used on product pages
                                      to prevent the current product from appearing in related products.
                                      When nil (not passed), no product is skipped. All 5 call sites
                                      outside product recommendations do not pass this parameter.
    collection:             {Object}  Optional. Passed through to product-thumbnail for within-collection URLs.
{%- endcomment -%}
{% assign collection_group = products | map: 'id' %}
{% assign collection_group_thumb = collection_group | append : 'thumb' %}
{% assign collection_group_mobile = collection_group | append : 'mobile' %}

{% if related_products == true %}
  {% assign hover_enabled = block.settings.show_related_products_title_on_hover %}
{% else %}
  {% assign hover_enabled = settings.thumbnail_hover_enabled %}
{% endif %}

{% if related_products == true %}
  {% assign related_items = true %}
{% else %}
  {% assign related_items = false %}
{% endif %}

{%- comment -%}
  Single-pass loop: iterate products with inline skip logic.
  Rendered count automatically stops at 'limit' when skip_product is nil.
  When skip_product matches, we fetch one extra product to maintain limit count.
{%- endcomment -%}
{% assign rendered_count = 0 %}
{% assign skip_id = skip_product.id %}

{% for product in products %}
  {%- if product.id == skip_id -%}
    {%- continue -%}
  {%- endif -%}

  {%- if rendered_count >= limit -%}
    {%- break -%}
  {%- endif -%}

  {% render 'product-thumbnail',
          product: product,
          limit: limit,
          products_per_row: products_per_row,
          mobile_products_per_row: mobile_products_per_row,
          align_height: align_height,
          height: height,
          collection_group_thumb: collection_group_thumb,
          collection_group_mobile: collection_group_mobile,
          related_products: related_items
  %}

  {%- assign rendered_count = rendered_count | plus: 1 -%}
{% endfor %}
