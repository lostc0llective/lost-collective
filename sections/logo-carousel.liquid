<div class="logo-carousel">
  <div class="logo-track">
    <!-- First Loop of Logos -->
    {% assign logos = "
      https://cdn.shopify.com/s/files/1/1304/3623/files/abc-logo_1600x.jpg?v=1735692404,
      https://cdn.shopify.com/s/files/1/1304/3623/files/7-news-logo_1600x.jpg?v=1735692349,
      https://cdn.shopify.com/s/files/1/1304/3623/files/the-sydney-morning-herald-logo_1600x.jpg?v=1735692443,
      https://cdn.shopify.com/s/files/1/1304/3623/files/cnn-logo_1600x.jpg?v=1735692552,
      https://cdn.shopify.com/s/files/1/1304/3623/files/business-insider-logo-greyscale_1600x.jpg?v=1735692506,
      https://cdn.shopify.com/s/files/1/1304/3623/files/commercial-real-estate-logo_1600x.jpg?v=1735692650,
      https://cdn.shopify.com/s/files/1/1304/3623/files/atomos-logo_1600x.jpg?v=1735692673,
      https://cdn.shopify.com/s/files/1/1304/3623/files/rnz-logo_1600x.jpg?v=1735692809,
      https://cdn.shopify.com/s/files/1/1304/3623/files/vice-logo_1600x.jpg?v=1735692781,
      https://cdn.shopify.com/s/files/1/1304/3623/files/curbed-logo-greyscale_1600x.jpg?v=1735692762,
      https://cdn.shopify.com/s/files/1/1304/3623/files/the-sun-logo_1600x.jpg?v=1735692575,
      https://cdn.shopify.com/s/files/1/1304/3623/files/smith-journal-logo_1600x.jpg?v=1735692600,
      https://cdn.shopify.com/s/files/1/1304/3623/files/domain-logo_1600x.jpg?v=1657695077,
      https://cdn.shopify.com/s/files/1/1304/3623/files/broad-logo_1600x.jpg?v=1735692698,
      https://cdn.shopify.com/s/files/1/1304/3623/files/capture-mag-logo_1600x.jpg?v=1735692727,
      https://cdn.shopify.com/s/files/1/1304/3623/files/nikon-logo_1600x.jpg?v=1735692529,
      https://cdn.shopify.com/s/files/1/1304/3623/files/pedestrian-logo_1600x.jpg?v=1735692625,
      https://cdn.shopify.com/s/files/1/1304/3623/files/the-guardian-logo_1600x.jpg?v=1735692377
    " | split: "," %}

    {% for logo in logos %}
      <div class="logo-slide">
        <img src="{{ logo | strip }}" alt="Logo" loading="lazy">
      </div>
    {% endfor %}

    <!-- Duplicate Logos for Infinite Scrolling -->
    {% for logo in logos %}
      <div class="logo-slide">
        <img src="{{ logo | strip }}" alt="Logo" loading="lazy">
      </div>
    {% endfor %}
  </div>
</div>

<style>
  .logo-carousel {
    overflow: hidden;
    width: 100%;
    background-color: #f9f9f9;
    padding: 10px 0;
    position: relative;
    white-space: nowrap;
  }
  
  .logo-track {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 20px;
    animation: scroll 30s linear infinite;
    width: calc(180px * 18 * 2); /* Adjusted width for 18 logos */
  }
  
  .logo-slide {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 180px; /* Adjust logo size */
  }
  
  .logo-slide img {
    max-width: 100%;
    max-height: 80px; /* Adjust logo height */
    object-fit: contain;
  }
  
  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); } /* Moves only half of the duplicated content */
  }
</style>