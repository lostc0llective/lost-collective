{% comment %}
  @param image
    An Image Drop to display.

  @param alt
    Alt text for the image.

  @param progressive {Boolean} (optional)
    If true, image is progressive (pjpg format).

  @param stretch_width {Boolean} (optional)
    If true, remove the max-width from the image tag.

  @param additional_classes {String} (optional)
    Additional classes added to the image tag.

  @param additional_wrapper_classes {String} (optional)
    Additional classes added to the image element wrap tag.

  @param inline_style {String} (optional)
    CSS styles to apply to the image tag's style attribute.
    Defaults to blank.

  @param back_to_basics {Boolean} (optional)
    If true, use standard image tag.

  @param height {Number} (optional)
    The height to set the image to.

  @param max_height {Number} (optional)
    The max height to set the image to.

  @param object_fit {Boolean} (optional)
    If true, preserves the image's max-height and aspect ratio.

  @param image_crop {Boolean} (optional)
    If true, crops the image to the max_height.

  @param focal_point {String} (optional)
    Applies focal point styles to the image.
    Defaults to blank.

  @param fetchpriority {String} (optional)
    Set to 'high' for above-fold images (hero, first visible image).
    Skips lazysizes; outputs standard eager-loaded img instead.
    Defaults to blank (lazy loading).
{% endcomment %}

{% liquid
  assign inline_style = inline_style | default: blank
  assign focal_point = focal_point | default: blank
  assign fetchpriority_attr = fetchpriority | default: blank
  if fetchpriority_attr == 'high'
    assign loading_attr = 'eager'
    assign use_lazyload = false
  else
    assign use_lazyload = true
  endif
%}

{% if focal_point != blank %}
  {%- capture focal_point_style -%}
    object-fit:cover;object-position:{{ focal_point }};
  {%- endcapture -%}

  {% if inline_style != blank %}
    {% assign inline_style = inline_style | append: focal_point_style %}
  {% else %}
    {% assign inline_style = focal_point_style %}
  {% endif %}
{% endif %}

{%- capture srcset -%}
  {% if progressive %}
    {{ image | image_url: width: 320, format: 'pjpg' }} 320w,
    {{ image | image_url: width: 640, format: 'pjpg' }} 640w,
    {{ image | image_url: width: 960, format: 'pjpg' }} 960w,
    {{ image | image_url: width: 1280, format: 'pjpg' }} 1280w,
    {{ image | image_url: width: 1600, format: 'pjpg' }} 1600w,
    {{ image | image_url: width: 1920, format: 'pjpg' }} 1920w
  {% else %}
    {{ image | image_url: width: 320 }} 320w,
    {{ image | image_url: width: 640 }} 640w,
    {{ image | image_url: width: 960 }} 960w,
    {{ image | image_url: width: 1280 }} 1280w,
    {{ image | image_url: width: 1600 }} 1600w,
    {{ image | image_url: width: 1920 }} 1920w
  {% endif %}
{%- endcapture -%}

{% if image_crop == true %}
  {% capture height_style %}
    {% if height %}height: {{ height }}px;{% endif %}
    max-height: {{ max_height }}px;
  {% endcapture %}
{% elsif object_fit == true %}
  {% capture height_style %}
    {% if height %}height: {{ height }}px;{% endif %}
    max-height: {{ max_height }}px; max-width: calc({{ image.width }} / {{ image.height }} * {{ max_height }}px);
  {% endcapture %}
{% else %}
  {% assign height_style = '' %}
{% endif %}

{% comment %}Loading style{% endcomment %}
{% if settings.image_loading_style == 'blur-up' %}
  {% assign low_quality_image = image | image_url: width: 50 %}
{% elsif settings.image_loading_style == 'color' %}
  {% assign dominant_color_image = image | image_url: width: 1 %}
  {% capture image_background_color %}background: url({{ dominant_color_image }});{% endcapture %}
{% endif %}

{% if back_to_basics %}
  <div
    class="image-element__wrap{% if additional_wrapper_classes %} {{ additional_wrapper_classes }}{% endif %}"
    style="{{ image_background_color }}{{ height_style }}"
    {% if mockup_orientation != blank %}data-mockup-orientation="{{ mockup_orientation }}"{% endif %}
  >
    <img
      alt="{{ alt | escape }}"
      src="{{ image | image_url: width: 2000 }}"
      loading="{{ loading_attr | default: 'lazy' }}"
      {% if fetchpriority_attr != blank %}fetchpriority="{{ fetchpriority_attr }}"{% endif %}
      style="{{ inline_style }}"
      {% if additional_classes %}class="{{ additional_classes }}"{% endif %}
    />
  </div>
{% else %}
  <div
    class="image-element__wrap{% if additional_wrapper_classes %} {{ additional_wrapper_classes }}{% endif %}"
    style="{{ image_background_color }}{{ height_style }}{% unless stretch_width == true or object_fit %} max-width: {{ image.width }}px;{% endunless %}"
    {% if mockup_orientation != blank %}data-mockup-orientation="{{ mockup_orientation }}"{% endif %}
  >
    {% if use_lazyload %}
      <img
        alt="{{ alt | escape }}"
        class="lazyload transition--{{ settings.image_loading_style }}{% if additional_classes %} {{ additional_classes }}{% endif %}"
        {% if low_quality_image %}src="{{ low_quality_image }}"{% endif %}
        data-src="{{ image | image_url: width: 1600 }}"
        data-sizes="auto"
        data-srcset="{{ srcset }}"
        data-aspectratio="{{ image.width }}/{{ image.height }}"
        height="{{ image.height }}"
        width="{{ image.width }}"
        srcset="data:image/svg+xml;utf8,<svg%20xmlns='http://www.w3.org/2000/svg'%20width='{{ image.width }}'%20height='{{ image.height }}'></svg>"
        style="{{ inline_style }}{{ height_style }};"
      />
    {% else %}
      <img
        alt="{{ alt | escape }}"
        class="transition--{{ settings.image_loading_style }}{% if additional_classes %} {{ additional_classes }}{% endif %}"
        loading="{{ loading_attr }}"
        fetchpriority="{{ fetchpriority_attr }}"
        src="{{ image | image_url: width: 1600 }}"
        srcset="{{ srcset }}"
        sizes="(max-width: 640px) 100vw, (max-width: 1024px) 80vw, 1600px"
        height="{{ image.height }}"
        width="{{ image.width }}"
        style="{{ inline_style }}{{ height_style }};"
      />
    {% endif %}
  </div>
{% endif %}

{% comment %}Fallback for no javascript{% endcomment %}
<noscript class="noscript">
  <img class="{{ additional_classes }}" src="{{ image | image_url: width: 2000 }}" alt="{{ alt | escape }}" style="{{ inline_style }}">
</noscript>
