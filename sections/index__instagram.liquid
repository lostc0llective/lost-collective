{% comment %}
** Instagram feed — endless horizontal marquee **
Fetches 12 posts from the Cloudflare Worker /instagram endpoint.
Posts duplicated in DOM for seamless infinite scroll via rAF.
Video posts autoplay muted inline.
{% endcomment %}

<section class="instagram-feed section" id="shopify-section-{{ section.id }}">
  <div class="instagram-feed__inner">

    <div class="instagram-feed__header">
      <p class="instagram-feed__heading">{{ section.settings.heading }}</p>
    </div>

    <div class="instagram-feed__track-wrap">
      <div class="instagram-feed__track" id="ig-track" aria-label="Instagram posts">
        {% for i in (1..24) %}
          <div class="instagram-feed__skeleton" aria-hidden="true"></div>
        {% endfor %}
      </div>
    </div>

    <div class="instagram-feed__footer">
      <a href="https://www.instagram.com/lostc0llective/" target="_blank" rel="noopener noreferrer" class="instagram-feed__follow">
        Follow @lostc0llective on Instagram →
      </a>
    </div>

  </div>
</section>

<style>
  .instagram-feed {
    background: #ffffff;
    padding-top: 52px;
    padding-bottom: 56px;
    overflow: hidden;
  }

  .instagram-feed__header {
    text-align: center;
    margin-bottom: 28px;
    padding: 0 1.5rem;
  }

  /* <p> tag avoids inheriting the theme's h2 uppercase + 27px treatment */
  .instagram-feed__heading {
    font-family: {{ settings.heading__font.family }}, {{ settings.heading__font.fallback_families }};
    font-weight: {{ settings.heading__font.weight }};
    font-size: 0.95rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: {{ settings.heading_color }};
    margin: 0;
    line-height: 1.4;
  }

  .instagram-feed__track-wrap {
    position: relative;
  }

  .instagram-feed__track {
    display: flex;
    gap: 24px;
    overflow-x: scroll;
    scroll-snap-type: none;
    -webkit-overflow-scrolling: touch;
    padding: 10px 1.5rem 20px;
    scrollbar-width: none;
    -ms-overflow-style: none;
    min-height: 290px;
    cursor: grab;
  }

  .instagram-feed__track:active { cursor: grabbing; }
  .instagram-feed__track::-webkit-scrollbar { display: none; }

  /* 4:5 portrait ratio — Instagram grid standard */
  .instagram-feed__tile,
  .instagram-feed__skeleton {
    flex: 0 0 200px;
    width: 200px;
    height: 250px;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.22);
    transition: box-shadow 250ms ease, transform 250ms ease;
  }

  .instagram-feed__tile:hover {
    box-shadow: 0 10px 32px rgba(0, 0, 0, 0.30);
    transform: translateY(-3px);
  }

  .instagram-feed__skeleton {
    background: #f0eeea;
    animation: ig-shimmer 1.4s ease-in-out infinite;
  }

  @keyframes ig-shimmer {
    0%, 100% { opacity: 0.45; }
    50%       { opacity: 0.85; }
  }

  .instagram-feed__tile a {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }

  .instagram-feed__tile img,
  .instagram-feed__tile video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 12px;
    transition: transform 350ms ease;
  }

  .instagram-feed__tile:hover img,
  .instagram-feed__tile:hover video {
    transform: scale(1.05);
  }

  .instagram-feed__tile__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 250ms ease;
    display: flex;
    align-items: flex-end;
    padding: 12px;
    border-radius: 12px;
  }

  .instagram-feed__tile:hover .instagram-feed__tile__overlay {
    opacity: 1;
  }

  .instagram-feed__tile__caption {
    font-family: {{ settings.body__font.family }}, {{ settings.body__font.fallback_families }};
    font-size: 0.72rem;
    line-height: 1.45;
    color: rgba(255,255,255,0.92);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .instagram-feed__footer {
    text-align: center;
    margin-top: 6px;
    padding: 0 1.5rem;
  }

  .instagram-feed__follow {
    font-family: {{ settings.body__font.family }}, {{ settings.body__font.fallback_families }};
    font-size: 0.88rem;
    color: {{ settings.regular_color }};
    text-decoration: none;
    border-bottom: 1px solid {{ settings.regular_color }};
    padding-bottom: 1px;
    transition: color 150ms ease, border-color 150ms ease;
  }

  .instagram-feed__follow:hover {
    color: {{ settings.link_color }};
    border-color: {{ settings.link_color }};
  }

  @media (min-width: 799px) {
    .instagram-feed__tile,
    .instagram-feed__skeleton {
      flex: 0 0 240px;
      width: 240px;
      height: 300px;
    }
    .instagram-feed__track { min-height: 350px; }
  }

  @media (min-width: 1200px) {
    .instagram-feed__tile,
    .instagram-feed__skeleton {
      flex: 0 0 270px;
      width: 270px;
      height: 337px;
    }
    .instagram-feed__track { min-height: 390px; }
  }
</style>

<script>
(function () {
  var ENDPOINT = 'https://lost-collective-webhooks.fragrant-union-3149.workers.dev/instagram';
  var SPEED    = 0.5;
  var track    = document.getElementById('ig-track');
  if (!track) return;

  var paused    = false;
  var dragging  = false;
  var dragStart = 0;
  var dragScroll = 0;
  var halfWidth  = 0;

  track.addEventListener('mousedown', function(e) {
    dragging   = true;
    paused     = true;
    dragStart  = e.pageX - track.offsetLeft;
    dragScroll = track.scrollLeft;
  });
  document.addEventListener('mouseup', function() {
    if (!dragging) return;
    dragging = false;
    paused   = false;
  });
  track.addEventListener('mousemove', function(e) {
    if (!dragging) return;
    e.preventDefault();
    track.scrollLeft = dragScroll - (e.pageX - track.offsetLeft - dragStart) * 1.2;
  });
  track.addEventListener('mouseenter', function() { if (!dragging) paused = true; });
  track.addEventListener('mouseleave', function() { paused = false; });

  function step() {
    if (!paused && halfWidth > 0) {
      track.scrollLeft += SPEED;
      if (track.scrollLeft >= halfWidth) track.scrollLeft -= halfWidth;
    }
    requestAnimationFrame(step);
  }

  function renderTile(post) {
    var tile = document.createElement('div');
    tile.className = 'instagram-feed__tile';

    var media;
    if (post.type === 'VIDEO' && post.video_url) {
      media = document.createElement('video');
      media.src           = post.video_url;
      media.autoplay      = true;
      media.muted         = true;
      media.loop          = true;
      media.playsInline   = true;
      media.setAttribute('playsinline', '');
      media.setAttribute('preload', 'none');
      media.poster        = post.url;
    } else {
      media = document.createElement('img');
      media.src     = post.url;
      media.alt     = post.caption ? post.caption.replace(/"/g, '&quot;') : 'Instagram post';
      media.loading = 'lazy';
      media.decoding = 'async';
    }

    var link = document.createElement('a');
    link.href   = post.link;
    link.target = '_blank';
    link.rel    = 'noopener noreferrer';
    link.setAttribute('aria-label', 'View on Instagram');
    link.appendChild(media);

    if (post.caption) {
      var overlay = document.createElement('div');
      overlay.className = 'instagram-feed__tile__overlay';
      var cap = document.createElement('p');
      cap.className   = 'instagram-feed__tile__caption';
      cap.textContent = post.caption;
      overlay.appendChild(cap);
      link.appendChild(overlay);
    }

    tile.appendChild(link);
    return tile;
  }

  fetch(ENDPOINT)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data.posts || !data.posts.length) return;
      track.innerHTML = '';
      var posts = data.posts;
      posts.forEach(function(p) { track.appendChild(renderTile(p)); });
      posts.forEach(function(p) { track.appendChild(renderTile(p)); });

      requestAnimationFrame(function() {
        var tile = track.querySelector('.instagram-feed__tile');
        if (tile) halfWidth = (tile.offsetWidth + 24) * posts.length;
        step();
      });
    })
    .catch(function(err) {
      console.warn('[LC Instagram] Feed unavailable:', err);
      track.innerHTML = '';
    });
})();
</script>

{% schema %}
{
  "name": "Instagram feed",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See the Story Unfold on Instagram"
    }
  ],
  "presets": [{ "name": "Instagram feed" }]
}
{% endschema %}
