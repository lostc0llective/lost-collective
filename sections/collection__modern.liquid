{% comment %}
** Collection - modern template **
{% endcomment %}

{% assign id = section.id %}
{% comment %}Layout{% endcomment %}
{% assign width = section.settings.width %}
{% assign padding_top = section.settings.padding_top %}
{% assign padding_bottom = section.settings.padding_bottom %}
{% assign animation = section.settings.animation | default: 'none' %}
{% comment %} Advanced {% endcomment %}
{% assign css_class = section.settings.css_class %}
{% assign custom_css = section.settings.custom_css %}

{% comment %} CSS {% endcomment %}
{% style %}
  #shopify-section-{{ id }} {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    {% if width == 'wide' %}
      width: 100%;
    {% endif %}
  }

  {% if section.settings.show_breadcrumb == false %}
    .breadcrumb__container {
      display: none;
    }
  {% endif %}

  {% if section.settings.pagination_type != 'basic_pagination' %}
    .breadcrumb__page-count {
      display: none;
    }
  {% endif %}

  {% render 'css-loop',
          css: custom_css,
          id: id
  %}
{% endstyle %}

<section id="{{ id }}" class="section
        {{ css_class }}
        is-width-{{ width }}"
        {% if animation != "none" %}
          data-scroll-class="{{ animation }}"
        {% endif %}>
  <div class="container {% if settings.heading_divider_style == 'long' %}has-heading-divider-below {% endif %}">
    <div class="collection__breadcrumb two-fifths medium-down--one-whole column has-padding-bottom">
      {% comment %} Collection breadcrumb {% endcomment %}
      <div class="breadcrumb__container">
        {% render 'breadcrumb', context: 'collection' %}
      </div>
    </div>
    <div class="collection__spacer three-fifths column hide-when-banner-enabled"></div>
    <div class="one-whole column has-no-side-gutter hide-when-banner-enabled">
      {% comment %} Collection title {% endcomment %}
      {% render 'heading',
              title: collection.title,
              heading_tag: 'h1',
              context: 'collection',
              text_alignment: 'left'
      %}
    </div>
    {% if settings.heading_divider_width != 0 and settings.heading_divider_style == 'long' %}
      <div class="heading-divider-below heading-wrapper one-whole column hide-when-banner-enabled">
        <div class="heading-divider
                    heading-divider--{{ settings.heading_divider_style }}"
              {% if settings.heading_divider_animation != "none" %}
                data-scroll-class="{{ settings.heading_divider_animation }}"
              {% endif %}>
        </div>
      </div>
    {% endif %}
  </div>

  {% comment %} Collection description {% endcomment %}
  {% if collection.description != blank %}
    <div class="container">
      <div class="one-whole column">
        <div class="collection__description content has-padding-bottom">
          {{ collection.description }}
        </div>
      </div>
    </div>
  {% endif %}

  {% comment %} Collection sidebar and main content area {% endcomment %}
  <div class="container collection__content">
    <div class="one-whole column">
      {% capture slot_pagination %}
        <div
          class="container container--pagination"
          style="margin-top: {{ section.settings.grid_spacing }}px; padding-top: 20px;"
        >
          <div class="one-whole column text-align-center">
            {% render 'new-pagination',
              collection: collection,
              items_per_page: section.settings.items_per_page
            %}
          </div>
        </div>
      {% endcapture %}

      {% liquid
        if settings.toggle_icon_style == 'carets'
          assign accordion_icon_open = 'chevron-up'
          assign accordion_icon_closed = 'chevron-down'
        else
          assign accordion_icon_open = 'minus'
          assign accordion_icon_closed = 'plus'
        endif
      %}

      {% render 'section.collection-feed',
        context: collection,
        items_per_page: section.settings.items_per_page,
        columns_desktop: section.settings.products_per_row,
        columns_mobile: section.settings.mobile_products_per_row,
        show_layout_controls: section.settings.show_grid_layout_controls,
        show_list_view: false,
        feed_view_default: section.settings.grid_layout,
        horizontal_gap_md: section.settings.grid_spacing,
        vertical_gap_md: section.settings.grid_spacing,

        sidebar_placement: section.settings.sidebar_placement,
        show_sort_by: section.settings.show_sort_by,
        show_filters: section.settings.show_filters,
        show_product_count: section.settings.show_product_count,
        open_filters: section.settings.open_filters,
        sticky_control_bar_mobile: false,

        accordion_icon_open: accordion_icon_open,
        accordion_icon_closed: accordion_icon_closed,

        slot_pagination: slot_pagination
      %}
    </div>
  </div>
</section>

{% javascript %}
  if (Shopify.designMode) {
    // Close overlay-drawer when any section is selected in theme editor
    document.addEventListener('shopify:section:select', function() {
      const overlayDrawer = document.querySelector('overlay-drawer');
      if (overlayDrawer) overlayDrawer.close();
    });
  }
{% endjavascript %}

<script data-theme-editor-load-script src="{{ 'z__jsSidebar.js' | asset_url }}"></script>
<script src="{{ 'z__jsCollection.js' | asset_url }}"></script>

{% if section.settings.thumbnail_aspect_ratio != 'adapt' %}
  {% assign aspect_parts = section.settings.thumbnail_aspect_ratio | split: '/' %}
  {% assign aspect_width = aspect_parts[0] | times: 1 %}
  {% assign aspect_height = aspect_parts[1] | times: 1 %}
  {% assign aspect_ratio_value = aspect_width | append: ' / ' | append: aspect_height %}
  
  {% style %}
    .collection-main .product__thumbnail .image__container,
    .collection-main .product__thumbnail .image-element__wrap {
      aspect-ratio: {{ aspect_ratio_value }};
      overflow: hidden;
    }
    
    .collection-main .product__thumbnail .image__container img,
    .collection-main .product__thumbnail .image-element__wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    
    /* Handle secondary images (hover effect) */
    .collection-main .product__thumbnail .image__container .secondary,
    .collection-main .product__thumbnail .image-element__wrap .secondary {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    }
    
    .collection-main .product__thumbnail .image__container .secondary img,
    .collection-main .product__thumbnail .image-element__wrap .secondary img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    
    /* Ensure video thumbnails also respect aspect ratio */
    .collection-main .product__thumbnail .product-thumbnail__video {
      aspect-ratio: {{ aspect_ratio_value }};
      overflow: hidden;
    }
    
    .collection-main .product__thumbnail .product-thumbnail__video video {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    

  {% endstyle %}
{% endif %}

{% schema %}
{
  "name": "Collection - modern",
  "class": "collection-main jsCollection jsSidebar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "range",
      "id": "items_per_page",
      "label": "Products per page",
      "min": 6,
      "max": 50,
      "step": 1,
      "default": 36
    },
    {
      "type": "range",
      "id": "products_per_row",
      "label": "Products per row",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "info": "Only applies on desktop when product grid layout is set to Standard view."
    },
    {
      "type": "select",
      "id": "mobile_products_per_row",
      "label": "Products per row on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_grid_layout_controls",
      "label": "Show grid layout controls",
      "default": true
    },
    {
      "type": "select",
      "id": "grid_layout",
      "label": "Default layout",
      "options": [
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "compact",
          "label": "Compact"
        }
      ],
      "default": "standard"
    },
    {
      "type": "header",
      "content": "Product thumbnails"
    },
    {
      "type": "select",
      "id": "thumbnail_aspect_ratio",
      "label": "Thumbnail aspect ratio",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to image"
        },
        {
          "value": "2/3",
          "label": "Portrait (2:3)"
        },
        {
          "value": "4/5",
          "label": "Portrait (4:5)"
        },
        {
          "value": "1/1",
          "label": "Square (1:1)"
        },
        {
          "value": "3/2",
          "label": "Landscape (3:2)"
        }
      ],
      "default": "adapt"
    },
    {
      "type": "header",
      "content": "Filters and sort"
    },
    {
      "type": "paragraph",
      "content": "Customize filters with the [Search & Discovery app](https://apps.shopify.com/search-discovery)."
    },
    {
      "type": "select",
      "id": "sidebar_placement",
      "label": "Filters position",
      "options": [
        {
          "value": "start",
          "label": "Left"
        },
        {
          "value": "end",
          "label": "Right"
        }
      ],
      "default": "start"
    },
    {
      "type": "checkbox",
      "id": "show_sort_by",
      "label": "Show sort by",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Show filters",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count per filter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "open_filters",
      "label": "Open filter groups by default",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing",
      "min": 0,
      "max": 80,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 80,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "grid_spacing",
      "label": "Grid spacing",
      "min": 0,
      "max": 60,
      "default": 30,
      "unit": "px"
    }
  ]
}

{% endschema %}
